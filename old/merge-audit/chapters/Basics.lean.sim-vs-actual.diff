< theorem notb_involutive : ∀ b : Bool,
<     (!!b) = b := by
<   intro b
<   cases b
<   case true => rfl
<   case false => rfl
< 
< -- TERSE: /- *** -/
< -- TERSE: /- We can have nested case analysis: -/
< 
< theorem andb_commutative : ∀ b c : Bool,
<     (b && c) = (c && b) := by
<   intro b c
<   cases b
<   case true =>
<     cases c
<     case true => rfl
<     case false => rfl
<   case false =>
<     cases c
<     case true => rfl
<     case false => rfl
< 
< theorem andb3_exchange : ∀ b c d : Bool,
<     ((b && c) && d) = ((b && d) && c) := by
<   intro b c d
<   cases b
<   case false =>
<     cases c
<     case true =>
<       cases d
<       case false => rfl
<       case true => rfl
<     case false =>
<       cases d
<       case false => rfl
<       case true => rfl
<   case true =>
<     cases c
<     case true =>
<       cases d
<       case false => rfl
<       case true => rfl
<     case false =>
<       cases d
<       case false => rfl
<       case true => rfl
