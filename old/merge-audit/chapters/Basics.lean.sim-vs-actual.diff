< -- /FULL
< 
< -- TERSE: /- *** -/
< -- TERSE: /- We can deconstruct a nibble by pattern-matching. -/
< 
< def allZero (nb : Nibble) : Bool :=
<   match nb with
<   | .bits .b0 .b0 .b0 .b0 => true
<   | .bits _   _   _   _   => false
