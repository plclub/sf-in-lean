< -- ############################################
< -- ** Manual vs. Automated: Arithmetic
< 
< -- From IndProp, recall `le_plus_l`:
< --   ∀ (a b : Nat), a ≤ a + b
< 
< -- Manual style required induction.  With `omega`:
< theorem le_plus_l_v2 : ∀ (a b : Nat), a ≤ a + b := by omega
< 
< -- Similarly, `plus_le`:
< --   ∀ (n1 n2 m : Nat), n1 + n2 ≤ m → n1 ≤ m ∧ n2 ≤ m
< theorem plus_le_v2 : ∀ (n1 n2 m : Nat),
<     n1 + n2 ≤ m → n1 ≤ m ∧ n2 ≤ m := by omega
< 
< -- `lt_ge_cases` from IndProp:
< --   ∀ (n m : Nat), n < m ∨ n ≥ m
< theorem lt_ge_cases_v2 : ∀ (n m : Nat), n < m ∨ n ≥ m := by omega
< 
< -- ############################################
< -- ** Manual vs. Automated: Logic
< 
< -- From Logic, conjunction commutativity:
< theorem and_comm_v2 {P Q : Prop} : P ∧ Q → Q ∧ P := by
<   intro ⟨hp, hq⟩; exact ⟨hq, hp⟩
< 
< -- With our custom tactic:
< theorem and_comm_v3 {P Q : Prop} (h : P ∧ Q) : Q ∧ P := by
<   obtain ⟨hp, hq⟩ := h; prop_search
< 
< -- Modus ponens:
< theorem mp_auto {P Q : Prop} (h1 : P) (h2 : P → Q) : Q := by
<   exact h2 h1
< 
< -- ############################################
< -- ** Choosing the Right Tactic
< 
< -- Here is a rough guide for choosing which tactic to use:
< --
< -- - Equational rewriting / simplification: `simp`
< -- - Linear arithmetic (Nat/Int): `omega`
< -- - Concrete decidable propositions: `decide`
< -- - Propositional logic / constructors: `constructor` + `assumption`
< -- - Everything else: manual proof, possibly with tactical combinators
< --
< -- In practice, experienced Lean users develop an intuition for which
< -- tactic to try first.  When in doubt, try `simp` or `omega` -- if
< -- they solve the goal, great; if not, you have lost nothing.
< 
