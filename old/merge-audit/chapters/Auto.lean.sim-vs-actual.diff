< -- EX3? (decide_ev)
< -- We can make `Ev` decidable!  Fill in the instance below.
< -- Then `decide` can prove `Ev` goals for concrete numbers.
< 
< instance : Decidable (Ev 0) := isTrue Ev.ev_0
< 
< instance : Decidable (Ev 1) := isFalse (by intro h; cases h)
< 
< instance (n : Nat) [inst : Decidable (Ev n)] : Decidable (Ev (n + 2)) :=
<   -- ADMITTED
<   match inst with
<   | isTrue h  => isTrue (Ev.ev_SS n h)
<   | isFalse h => isFalse (fun h2 => by cases h2 with | ev_SS _ h' => exact h h')
<   -- /ADMITTED
< 
< -- Now `decide` works for concrete `Ev` goals:
< theorem ev_20_decide : Ev 20 := by decide
< 
< theorem not_ev_15 : ¬ Ev 15 := by decide
