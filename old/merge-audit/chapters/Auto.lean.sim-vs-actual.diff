< -- /ADMITTED
< 
< theorem le_3_5_custom : Playground.Le 3 5 := by
<   -- ADMITTED
<   prove_le
<   -- /ADMITTED
< 
< -- ######################################################################
< -- * Putting It All Together
< 
< -- Let us revisit some theorems from earlier chapters and see how
< -- automation can simplify the proofs.
< 
< -- ############################################
< -- ** Manual vs. Automated: Ev examples
< 
< -- Manual proof of `ev_plus4` (from IndProp):
< theorem ev_plus4_manual : ∀ (n : Nat), Ev n → Ev (4 + n) := by
<   intro n hn
<   have h : 4 + n = (n + 2) + 2 := by omega
<   rw [h]
<   exact Ev.ev_SS _ (Ev.ev_SS _ hn)
< 
< -- With automation, the arithmetic becomes trivial, though we still
< -- need to guide the inductive structure:
< theorem ev_plus4_auto : ∀ (n : Nat), Ev n → Ev (4 + n) := by
<   intro n hn
<   have h : 4 + n = (n + 2) + 2 := by omega
<   rw [h]
<   exact Ev.ev_SS _ (Ev.ev_SS _ hn)
