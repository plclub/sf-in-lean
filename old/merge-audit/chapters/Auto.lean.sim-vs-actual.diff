< -- EX2? (ev_sum_auto)
< -- Re-prove `ev_sum` from IndProp using as much automation as possible.
< -- You will still need some manual steps (like induction), but the
< -- individual cases should be easier.
< 
< theorem ev_sum_auto : ∀ (n m : Nat), Ev n → Ev m → Ev (n + m) := by
<   -- ADMITTED
<   intro n m hn hm
<   induction hn with
<   | ev_0 => simpa
<   | ev_SS n _ ih =>
<     have : n + 2 + m = (n + m) + 2 := by omega
<     rw [this]
<     exact Ev.ev_SS _ ih
<   -- /ADMITTED
< 
< -- EX3? (ev_ev__ev_auto)
< -- Re-prove `ev_ev__ev` from IndProp.  Use automation where you can
< -- to shorten the proof, but you will likely need manual case analysis.
< 
< theorem ev_ev__ev_auto : ∀ (n m : Nat),
<     Ev (n + m) → Ev n → Ev m := by
<   -- ADMITTED
<   intro n m hnm hn
<   induction hn with
<   | ev_0 => simpa using hnm
<   | ev_SS n _ ih =>
<     apply ih
<     have : n + 2 + m = (n + m) + 2 := by omega
<     rw [this] at hnm
<     cases hnm with
<     | ev_SS _ h => exact h
<   -- /ADMITTED
< 
