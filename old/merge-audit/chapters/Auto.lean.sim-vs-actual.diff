< -- EX4A? (subseq_trans_auto)
< -- Re-prove `subseq_trans` from IndProp, using automation to make
< -- the proof shorter.  You will still need induction and case analysis,
< -- but tactics like `assumption` and `exact` can help with individual
< -- cases.
< 
< theorem subseq_trans_auto : ∀ (l1 l2 l3 : List Nat),
<     Subseq l1 l2 →
<     Subseq l2 l3 →
<     Subseq l1 l3 := by
<   -- ADMITTED
<   intro l1 l2 l3 s12 s23
<   induction s23 generalizing l1 with
<   | sub_nil _ =>
<     cases s12; exact Subseq.sub_nil _
<   | sub_take x _ _ _ ih =>
<     cases s12 with
<     | sub_nil _ => exact Subseq.sub_nil _
<     | sub_take _ _ _ h1 => exact Subseq.sub_take x _ _ (ih _ h1)
<     | sub_skip _ _ _ h1 => exact Subseq.sub_skip x _ _ (ih _ h1)
<   | sub_skip x _ _ _ ih =>
<     exact Subseq.sub_skip x _ _ (ih _ s12)
<   -- /ADMITTED
