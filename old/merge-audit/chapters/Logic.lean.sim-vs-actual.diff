< -- forallb_true_iff
< theorem forallb_true_iff {X : Type} {test : X → Bool} {l : List X} :
<   forallb test l = true ↔ All (fun x => test x = true) l := by
<   -- ADMITTED
<   induction l with
<   | nil =>
<     simp [forallb, All]
