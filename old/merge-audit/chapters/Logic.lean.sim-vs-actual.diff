< -- Another common situation is that we know `A ∧ B` but in some
< -- context we need just `A` or just `B`.  In such cases we can use
< -- `obtain` and just discard the part we don't need.
< 
< -- proj1
< theorem proj1 {P Q : Prop} :
<   P ∧ Q → P := by
<   intro ⟨hp, _⟩
<   exact hp
