< -- EX1 (eqb_neq)
< -- The following theorem is an alternate "negative" formulation of
< -- `eqb_eq` that is more convenient in certain situations.
< 
< -- eqb_neq
< theorem eqb_neq {x y : Nat} :
<   Nat.beq x y = false ↔ x ≠ y := by
<   -- ADMITTED
<   constructor
<   · intro h hxy
<     subst hxy
<     have : Nat.beq x x = true := (eqb_eq).mpr rfl
<     rw [this] at h
<     exact absurd h (by decide)
<   · intro h
<     cases hbeq : Nat.beq x y with
<     | false => rfl
<     | true =>
<       exfalso
<       exact h (eqb_true x y hbeq)
<   -- /ADMITTED
< -- []
