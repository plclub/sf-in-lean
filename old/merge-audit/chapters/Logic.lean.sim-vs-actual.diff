< -- Hint: While getting accustomed to Lean's definition of `Not`, you might
< -- find it helpful to `simp only [Not]` or just `intro` near the beginning.
< 
< -- not_implies_our_not
< theorem not_implies_our_not {P : Prop} :
<   ¬P → (∀ (Q : Prop), P → Q) := by
<   -- ADMITTED
<   intro h Q hp
<   exact absurd hp h
<   -- /ADMITTED
