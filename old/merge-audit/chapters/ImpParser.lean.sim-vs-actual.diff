< 
< -- #######################################################
< -- * Internals
< 
< -- #######################################################
< -- ** Lexical Analysis
< 
< def isWhite (c : Char) : Bool :=
<   c == ' ' || c == '\t' || c == '\n' || c == (Char.ofNat 13)
< 
< def isLowerAlpha (c : Char) : Bool :=
<   'a' ≤ c && c ≤ 'z'
< 
< def isAlpha (c : Char) : Bool :=
<   ('A' ≤ c && c ≤ 'Z') || ('a' ≤ c && c ≤ 'z')
< 
< def isDigit (c : Char) : Bool :=
<   '0' ≤ c && c ≤ '9'
< 
< inductive Chartype where
<   | white | alpha | digit | other
< 
< open Chartype
< 
< def classifyChar (c : Char) : Chartype :=
<   if isWhite c then white
<   else if isAlpha c then alpha
<   else if isDigit c then digit
<   else other
< 
< abbrev Token := String
< 
< def tokenizeHelper (cls : Chartype) (acc : List Char) (xs : List Char)
<     : List (List Char) :=
<   let tk := match acc with | [] => [] | _ => [acc.reverse]
<   match xs with
<   | [] => tk
<   | x :: xs' =>
<     if x == '(' then
<       tk ++ [['(']] ++ tokenizeHelper other [] xs'
<     else if x == ')' then
<       tk ++ [[')']] ++ tokenizeHelper other [] xs'
<     else
<       match cls, classifyChar x with
<       | _, white      => tk ++ tokenizeHelper white [] xs'
<       | alpha, alpha  => tokenizeHelper alpha (x :: acc) xs'
<       | digit, digit  => tokenizeHelper digit (x :: acc) xs'
<       | other, other  => tokenizeHelper other (x :: acc) xs'
<       | _, tp         => tk ++ tokenizeHelper tp [x] xs'
< 
< def tokenize (s : String) : List String :=
<   (tokenizeHelper white [] s.toList).map (fun cs => String.ofList cs)
< 
< -- tokenize_ex1
< #eval tokenize "abc12=3  223*(3+(a+c))"
< -- = ["abc", "12", "=", "3", "223",
< --    "*", "(", "3", "+", "(",
< --    "a", "+", "c", ")", ")"]
< 
< -- #######################################################
< -- ** Parsing
< 
< -- *** Options With Errors
< 
< -- An option type with error messages:
< -- In Lean, we use `Except String` which provides `Except.ok` and
< -- `Except.error`.  This gives us `do` notation for free.
< 
< -- *** Generic Combinators for Building Parsers
< 
< abbrev Parser (T : Type) :=
<   List Token → Except String (T × List Token)
< 
< def manyHelper {T : Type} (p : Parser T) (acc : List T) (steps : Nat)
<     (xs : List Token) : Except String (List T × List Token) :=
<   match steps with
<   | 0 => .error "Too many recursive calls"
<   | Nat.succ steps' =>
<     match p xs with
<     | .error _ => .ok (acc.reverse, xs)
<     | .ok (t, xs') => manyHelper p (t :: acc) steps' xs'
< 
< -- A (step-indexed) parser that expects zero or more `p`s:
< 
< def many {T : Type} (p : Parser T) (steps : Nat) : Parser (List T) :=
<   manyHelper p [] steps
< 
< -- A parser that expects a given token, followed by `p`:
< 
< def firstExpect {T : Type} (t : Token) (p : Parser T) : Parser T :=
<   fun xs =>
<     match xs with
<     | x :: xs' =>
<       if x == t then p xs'
<       else .error s!"expected '{t}'."
<     | [] => .error s!"expected '{t}'."
< 
< -- A parser that expects a particular token:
< 
< def expect (t : Token) : Parser Unit :=
<   firstExpect t (fun xs => .ok ((), xs))
< 
< -- *** A Recursive-Descent Parser for Imp
< 
< -- Identifiers:
< 
< def parseIdentifier (xs : List Token) : Except String (String × List Token) :=
<   match xs with
<   | [] => .error "Expected identifier"
<   | x :: xs' =>
<     if x.toList.all isLowerAlpha then
<       .ok (x, xs')
<     else
<       .error s!"Illegal identifier:'{x}'"
< 
< -- Numbers:
< 
< def parseNumber (xs : List Token) : Except String (Nat × List Token) :=
<   match xs with
<   | [] => .error "Expected number"
<   | x :: xs' =>
<     if x.toList.all isDigit then
<       let n := x.toList.foldl (fun n d => 10 * n + (d.toNat - '0'.toNat)) 0
<       .ok (n, xs')
<     else
<       .error "Expected number"
< 
< -- Parse arithmetic expressions
< 
< -- We define the mutually recursive parsers using `mutual` ... `end`.
< 
< mutual
< 
< def parsePrimaryExp (steps : Nat) (xs : List Token)
<     : Except String (AExp × List Token) :=
<   match steps with
<   | 0 => .error "Too many recursive calls"
<   | Nat.succ steps' =>
<     -- Try identifier
<     match parseIdentifier xs with
<     | .ok (i, rest) => .ok (AId i, rest)
<     | .error _ =>
<     -- Try number
<     match parseNumber xs with
<     | .ok (n, rest) => .ok (ANum n, rest)
<     | .error _ =>
<     -- Try parenthesized expression
<     do
<       let (e, rest) ← firstExpect "(" (parseSumExp steps') xs
<       let (_, rest') ← expect ")" rest
<       .ok (e, rest')
< 
< def parseProductExp (steps : Nat) (xs : List Token)
<     : Except String (AExp × List Token) :=
<   match steps with
<   | 0 => .error "Too many recursive calls"
<   | Nat.succ steps' => do
<     let (e, rest) ← parsePrimaryExp steps' xs
<     let (es, rest') ← many (firstExpect "*" (parsePrimaryExp steps'))
<                             steps' rest
<     .ok (es.foldl AMult e, rest')
< 
< def parseSumExp (steps : Nat) (xs : List Token)
<     : Except String (AExp × List Token) :=
<   match steps with
<   | 0 => .error "Too many recursive calls"
<   | Nat.succ steps' => do
<     let (e, rest) ← parseProductExp steps' xs
<     let (es, rest') ←
<         many (fun xs =>
<                 match firstExpect "+" (parseProductExp steps') xs with
<                 | .ok (e, rest') => .ok ((true, e), rest')
<                 | .error _ => do
<                   let (e, rest') ← firstExpect "-" (parseProductExp steps') xs
<                   .ok ((false, e), rest'))
<              steps' rest
<     .ok (es.foldl (fun e0 term =>
<                     match term with
<                     | (true,  e) => APlus e0 e
<                     | (false, e) => AMinus e0 e)
<                   e,
<          rest')
< 
< end
< 
< def parseAExp := parseSumExp
< 
< -- Parsing boolean expressions:
< 
< mutual
< 
< def parseAtomicExp (steps : Nat) (xs : List Token)
<     : Except String (BExp × List Token) :=
<   match steps with
<   | 0 => .error "Too many recursive calls"
<   | Nat.succ steps' =>
<     -- Try "true"
<     match expect "true" xs with
<     | .ok (_, rest) => .ok (BTrue, rest)
<     | .error _ =>
<     -- Try "false"
<     match expect "false" xs with
<     | .ok (_, rest) => .ok (BFalse, rest)
<     | .error _ =>
<     -- Try "~" (negation)
<     match firstExpect "~" (parseAtomicExp steps') xs with
<     | .ok (e, rest) => .ok (BNot e, rest)
<     | .error _ =>
<     -- Try parenthesized boolean expression
<     match firstExpect "(" (parseConjunctionExp steps') xs with
<     | .ok (e, rest) =>
<       match expect ")" rest with
<       | .ok (_, rest') => .ok (e, rest')
<       | .error err => .error err
<     | .error _ =>
<     -- Try comparison: parse arithmetic then look for = or <=
<     match parseProductExp steps' xs with
<     | .error err => .error err
<     | .ok (e, rest) =>
<       match firstExpect "=" (parseAExp steps') rest with
<       | .ok (e', rest') => .ok (BEqA e e', rest')
<       | .error _ =>
<       match firstExpect "<=" (parseAExp steps') rest with
<       | .ok (e', rest') => .ok (BLe e e', rest')
<       | .error _ =>
<         .error "Expected '=' or '<=' after arithmetic expression"
< 
< def parseConjunctionExp (steps : Nat) (xs : List Token)
<     : Except String (BExp × List Token) :=
<   match steps with
<   | 0 => .error "Too many recursive calls"
<   | Nat.succ steps' => do
<     let (e, rest) ← parseAtomicExp steps' xs
<     let (es, rest') ← many (firstExpect "&&" (parseAtomicExp steps'))
<                             steps' rest
<     .ok (es.foldl BAnd e, rest')
< 
< end
< 
< def parseBExp := parseConjunctionExp
< 
< -- Parsing commands:
< 
< mutual
< 
< def parseSimpleCommand (steps : Nat) (xs : List Token)
<     : Except String (Com × List Token) :=
<   match steps with
<   | 0 => .error "Too many recursive calls"
<   | Nat.succ steps' =>
<     -- Try "skip"
<     match expect "skip" xs with
<     | .ok (_, rest) => .ok (CSkip, rest)
<     | .error _ =>
<     -- Try "if"
<     match firstExpect "if" (parseBExp steps') xs with
<     | .ok (e, rest) => do
<       let (c, rest') ← firstExpect "then" (parseSequencedCommand steps') rest
<       let (c', rest'') ← firstExpect "else" (parseSequencedCommand steps') rest'
<       let (_, rest''') ← expect "end" rest''
<       .ok (CIf e c c', rest''')
<     | .error _ =>
<     -- Try "while"
<     match firstExpect "while" (parseBExp steps') xs with
<     | .ok (e, rest) => do
<       let (c, rest') ← firstExpect "do" (parseSequencedCommand steps') rest
<       let (_, rest'') ← expect "end" rest'
<       .ok (CWhile e c, rest'')
<     | .error _ =>
<     -- Try assignment
<     match parseIdentifier xs with
<     | .ok (i, rest) => do
<       let (e, rest') ← firstExpect ":=" (parseAExp steps') rest
<       .ok (CAsgn i e, rest')
<     | .error _ =>
<       .error "Expecting a command"
< 
< def parseSequencedCommand (steps : Nat) (xs : List Token)
<     : Except String (Com × List Token) :=
<   match steps with
<   | 0 => .error "Too many recursive calls"
<   | Nat.succ steps' => do
<     let (c, rest) ← parseSimpleCommand steps' xs
<     match firstExpect ";" (parseSequencedCommand steps') rest with
<     | .ok (c', rest') => .ok (CSeq c c', rest')
<     | .error _ => .ok (c, rest)
< 
< end
< 
< def bignumber : Nat := 1000
< 
< def parse (str : String) : Except String Com :=
<   let tokens := tokenize str
<   match parseSequencedCommand bignumber tokens with
<   | .ok (c, []) => .ok c
<   | .ok (_, t :: _) => .error s!"Trailing tokens remaining: {t}"
<   | .error err => .error err
< 
< -- #######################################################
< -- * Examples
< 
< -- eg1
< #eval parse "
<   if x = y + 1 + 2 - y * 6 + 3 then
<     x := x * 1;
<     y := 0
<   else
<     skip
<   end  "
< 
< -- eg2
< #eval parse "
<   skip;
<   z:=x*y*(x*x);
<   while x=x do
<     if (z <= z*z) && ~(x = 2) then
<       x := z;
<       y := z
<     else
<       skip
<     end;
<     skip
<   end;
<   x:=z  "
