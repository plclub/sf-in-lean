< -- (inclusive -- i.e., 1 + 2 + ... + X) in the variable Y.  Make
< -- sure your solution satisfies the test that follows.
< 
< def pup_to_n' : Com
<   -- ADMITDEF
<   :=
<   CSeq (CAsgn Y (ANum 0))
<   (CWhile (BNot (BEqA (AId X) (ANum 0)))
<     (CSeq (CAsgn Y (APlus (AId Y) (AId X)))
