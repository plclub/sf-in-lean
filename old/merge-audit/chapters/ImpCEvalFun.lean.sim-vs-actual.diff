< -- ################################################################
< -- * Relational vs. Step-Indexed Evaluation
< 
< -- FULL: As for arithmetic and boolean expressions, we'd hope that
< -- the two alternative definitions of evaluation would actually
< -- amount to the same thing in the end.  This section shows that this
< -- is the case.
< 
< theorem ceval_step__ceval {c : Com} {st st' : State}
<     (H : ∃ i, cevalStep st c i = some st') :
<     st =[ c ]=> st' := by
<   obtain ⟨i, E⟩ := H
<   revert c st st'
<   induction i with
<   | zero =>
<     intro c st st' H
<     simp [cevalStep] at H
<   | succ i' ih =>
<     intro c st st' H
<     cases c with
<     | CSkip =>
<       simp [cevalStep] at H
<       subst H
<       exact CEval.E_Skip _
<     | CAsgn x a =>
<       simp [cevalStep] at H
<       subst H
<       exact CEval.E_Asgn _ _ _ _ rfl
<     | CSeq c1 c2 =>
<       simp [cevalStep] at H
<       cases heq : cevalStep st c1 i' with
<       | none => simp [heq] at H
<       | some s =>
<         simp [heq] at H
<         exact CEval.E_Seq c1 c2 st s st' (ih heq) (ih H)
<     | CIf b c1 c2 =>
<       simp [cevalStep] at H
<       cases hb : beval st b with
<       | true =>
<         simp [hb] at H
<         exact CEval.E_IfTrue _ _ _ _ _ hb (ih H)
<       | false =>
<         simp [hb] at H
<         exact CEval.E_IfFalse _ _ _ _ _ hb (ih H)
<     | CWhile b c =>
<       simp [cevalStep] at H
<       cases hb : beval st b with
<       | false =>
<         simp [hb] at H
<         subst H
<         exact CEval.E_WhileFalse _ _ _ hb
<       | true =>
<         simp [hb] at H
<         cases heq : cevalStep st c i' with
<         | none => simp [heq] at H
<         | some s =>
<           simp [heq] at H
<           exact CEval.E_WhileTrue st s st' b c hb (ih heq) (ih H)
< 
< -- FULL
< -- EX4AM (ceval_step__ceval_inf)
< -- Write an informal proof of ceval_step__ceval, following the
< -- usual template.  (The template for case analysis on an inductively
< -- defined value should look the same as for induction, except that
< -- there is no induction hypothesis.)  Make your proof communicate
< -- the main ideas to a human reader; do not simply transcribe the
< -- steps of the formal proof.
< 
< -- GRADE_MANUAL 6: ceval_step__ceval_inf
< -- /FULL
< 
< theorem ceval_step_more {i1 i2 : Nat} {st st' : State} {c : Com}
<     (hle : i1 ≤ i2)
<     (heval : cevalStep st c i1 = some st') :
<     cevalStep st c i2 = some st' := by
<   revert i2 st st' c
<   induction i1 with
<   | zero =>
<     intro i2 st st' c _ H
<     simp [cevalStep] at H
<   | succ i1' ih =>
<     intro i2 st st' c hle H
<     cases i2 with
<     | zero => omega
<     | succ i2' =>
<       have hle' : i1' ≤ i2' := Nat.le_of_succ_le_succ hle
<       cases c with
<       | CSkip =>
<         simp [cevalStep] at H ⊢
<         exact H
<       | CAsgn x a =>
<         simp [cevalStep] at H ⊢
<         exact H
<       | CSeq c1 c2 =>
<         simp [cevalStep] at H ⊢
<         cases heq : cevalStep st c1 i1' with
<         | none => simp [heq] at H
<         | some s =>
<           simp [heq] at H
<           rw [ih hle' heq]
<           exact ih hle' H
<       | CIf b c1 c2 =>
<         simp [cevalStep] at H ⊢
<         cases hb : beval st b with
<         | true => simp [hb] at H ⊢; exact ih hle' H
<         | false => simp [hb] at H ⊢; exact ih hle' H
<       | CWhile b c =>
<         simp [cevalStep] at H ⊢
<         cases hb : beval st b with
<         | false => simp [hb] at H ⊢; exact H
<         | true =>
<           simp [hb] at H ⊢
<           cases heq : cevalStep st c i1' with
<           | none => simp [heq] at H
<           | some s =>
<             simp [heq] at H
<             rw [ih hle' heq]
<             exact ih hle' H
< 
< -- FULL
< -- EX3! (ceval__ceval_step)
< -- Finish the following proof.  You'll need `ceval_step_more` in a
< -- few places, as well as some basic facts about `≤` and `+`.
< -- /FULL
< 
< theorem ceval__ceval_step {c : Com} {st st' : State}
<     (Hce : st =[ c ]=> st') :
<     ∃ i, cevalStep st c i = some st' := by
<   induction Hce with
<   | E_Skip st =>
<     exact ⟨1, rfl⟩
<   | E_Asgn st a n x ha =>
<     exact ⟨1, by simp [cevalStep, ha]⟩
<   | E_Seq c1 c2 st st' st'' _ _ ih1 ih2 =>
<     obtain ⟨i1, h1⟩ := ih1
<     obtain ⟨i2, h2⟩ := ih2
<     refine ⟨i1 + i2 + 1, ?_⟩
<     simp [cevalStep]
<     rw [ceval_step_more (by omega : i1 ≤ i1 + i2) h1]
<     exact ceval_step_more (by omega : i2 ≤ i1 + i2) h2
<   | E_IfTrue st st' b c1 c2 hb _ ih =>
<     obtain ⟨i1, h1⟩ := ih
<     exact ⟨i1 + 1, by simp [cevalStep, hb, h1]⟩
<   | E_IfFalse st st' b c1 c2 hb _ ih =>
<     obtain ⟨i1, h1⟩ := ih
<     exact ⟨i1 + 1, by simp [cevalStep, hb, h1]⟩
<   | E_WhileFalse b st c hb =>
<     exact ⟨1, by simp [cevalStep, hb]⟩
<   | E_WhileTrue st st' st'' b c hb _ _ ih1 ih2 =>
<     obtain ⟨i1, h1⟩ := ih1
<     obtain ⟨i2, h2⟩ := ih2
<     refine ⟨i1 + i2 + 1, ?_⟩
<     simp [cevalStep, hb]
<     rw [ceval_step_more (by omega : i1 ≤ i1 + i2) h1]
<     exact ceval_step_more (by omega : i2 ≤ i1 + i2) h2
< 
< theorem ceval_and_ceval_step_coincide {c : Com} {st st' : State} :
<     (st =[ c ]=> st')
<   ↔ (∃ i, cevalStep st c i = some st') :=
<   ⟨ceval__ceval_step, fun h => ceval_step__ceval h⟩
< 
< -- #######################################################
< -- * Determinism of Evaluation Again
< 
< -- Using the fact that the relational and step-indexed definition of
< -- evaluation are the same, we can give a slicker proof that the
< -- evaluation _relation_ is deterministic.
< 
< theorem ceval_deterministic' {c : Com} {st st1 st2 : State}
<     (He1 : st =[ c ]=> st1)
<     (He2 : st =[ c ]=> st2) :
<     st1 = st2 := by
<   obtain ⟨i1, E1⟩ := ceval__ceval_step He1
<   obtain ⟨i2, E2⟩ := ceval__ceval_step He2
<   have E1' := ceval_step_more (by omega : i1 ≤ i1 + i2) E1
<   have E2' := ceval_step_more (by omega : i2 ≤ i1 + i2) E2
<   rw [E1'] at E2'
<   exact Option.some.inj E2'
