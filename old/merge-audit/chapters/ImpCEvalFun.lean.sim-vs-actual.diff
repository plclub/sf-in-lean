< -- EX2? (peven)
< -- Write an Imp program that sets Z to 0 if X is even and
< -- sets Z to 1 otherwise.  Use testCeval to test your program.
< 
< -- SOLUTION
< def peven : Com :=
<   CSeq
<     (CWhile (BLe (ANum 2) (AId X))
<       (CAsgn X (AMinus (AId X) (ANum 2))))
<     (CIf (BEqA (AId X) (ANum 0))
<       (CAsgn Z (ANum 0))
<       (CAsgn Z (ANum 1)))
< 
< example :
<   testCeval (X !-> 2) peven
<   = some (0, 0, 0) := by rfl
< 
< example :
<   testCeval (X !-> 5) peven
<   = some (1, 0, 1) := by rfl
< -- /SOLUTION
