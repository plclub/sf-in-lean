<   -- ADMITTED
<   intro n
<   induction n with
<   | zero => intro _ _; rfl
<   | succ n' ih =>
<     intro m h
<     match m with
<     | 0 => omega
<     | m' + 1 =>
<       exact ih m' (Nat.le_of_succ_le_succ h)
