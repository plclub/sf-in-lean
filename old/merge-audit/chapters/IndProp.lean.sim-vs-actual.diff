< -- leb_complete
< theorem leb_complete' : ∀ (n m : Nat),
<   (n <=? m) = true → n ≤ m := by
<   -- ADMITTED
<   intro n
<   induction n with
<   | zero => intro m _; exact Nat.zero_le m
<   | succ n' ih =>
<     intro m h
<     match m with
<     | 0 => simp [leb] at h
<     | m' + 1 =>
<       apply Nat.succ_le_succ
<       exact ih m' h
